{
  "$schema": "https://jenesboot.local/schemas/palette-v1",
  "version": 1,
  "note": "Master palette for JenesBoot. Every color used anywhere in the game must have an entry here. New entries require a documented reason.",
  "colors": [
    {
      "id": "BG_DEEP",
      "hex": "#0a0e1a",
      "usage": "Void / sky background, deepest shadow"
    },
    {
      "id": "BG_WATER",
      "hex": "#0f1e2e",
      "usage": "Dark water fill, underwater ambient"
    },
    {
      "id": "WATER_MID",
      "hex": "#163245",
      "usage": "Mid-depth water band"
    },
    {
      "id": "WATER_SURF",
      "hex": "#1e4d6b",
      "usage": "Water surface shimmer / highlight line"
    },
    {
      "id": "HULL_DARK",
      "hex": "#2a2a2e",
      "usage": "Hull shadow, interior dark surfaces"
    },
    {
      "id": "HULL_MID",
      "hex": "#3c3c44",
      "usage": "Hull main body, structural mid-tone"
    },
    {
      "id": "HULL_LIGHT",
      "hex": "#5c5c6e",
      "usage": "Hull highlight, top-lit surfaces"
    },
    {
      "id": "RIVET",
      "hex": "#7a7a88",
      "usage": "Rivets, fine hull detail, seam ticks"
    },
    {
      "id": "ALIEN_TEAL",
      "hex": "#00e5cc",
      "usage": "Alien bioluminescence, conduit glow, porthole light — signals sci-fi"
    },
    {
      "id": "ALIEN_PURP",
      "hex": "#8833cc",
      "usage": "Secondary alien glow, deep energy signatures"
    },
    {
      "id": "ENEMY_HULL",
      "hex": "#4a2a1a",
      "usage": "Enemy / Nazi-faction ship hull (rust-brown, deliberate drab)"
    },
    {
      "id": "IRON_CROSS",
      "hex": "#6e3a1e",
      "usage": "Enemy faction emblem color — appears on antagonist hulls only, never glorified"
    },
    {
      "id": "TEXT_WHITE",
      "hex": "#e8e8e0",
      "usage": "Primary UI text, title text, bright labels"
    },
    {
      "id": "TEXT_DIM",
      "hex": "#8888a0",
      "usage": "Secondary / dimmed UI text, flavor copy, inactive states"
    }
  ]
}
