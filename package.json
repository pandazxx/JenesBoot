{
  "name": "jenesboot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "npm run headless:build && vitest run",
    "headless:build": "esbuild src/headless/runner.ts --bundle --platform=node --format=esm --outfile=dist-node/runner.js --external:pixi.js",
    "headless": "npm run headless:build && node dist-node/runner.js"
  },
  "dependencies": {
    "pixi.js": "8.9.2"
  },
  "devDependencies": {
    "@eslint/js": "9.26.0",
    "@types/node": "22.15.17",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "esbuild": "0.25.4",
    "eslint": "9.26.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.0",
    "vite": "6.3.4",
    "vitest": "3.1.3"
  }
}
